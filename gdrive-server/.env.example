# ─── Google OAuth Credentials ────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/
#   1. Create a project (or use existing)
#   2. Enable "Google Drive API"
#   3. Go to Credentials → Create OAuth 2.0 Client ID → Desktop App
#   4. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# ─── Optional: Root Google Drive Folder ID ────────────────────────────────────
# If you want all CMS uploads inside a specific Drive folder,
# paste its ID here (visible in the URL when you open the folder in Drive).
# Your shared Drive folder — already set in server.js
# 1ebqrJ0YPqtSiBIvLND-w6KDNnoivp7VG
GDRIVE_ROOT_FOLDER_ID=1ebqrJ0YPqtSiBIvLND-w6KDNnoivp7VG
REACT_APP_GDRIVE_PROXY=https://opt-cms-gdrive-proxy.onrender.com

# ─── Server Port (default 3001) ───────────────────────────────────────────────
PORT=3001
